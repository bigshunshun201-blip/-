{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "roco-shortdrama-studio",
  "account_id": "94fa027c90bd2f6ba36f15d1b2a4eda2",
  "main": "cloudflare/worker.mjs",
  "compatibility_date": "2026-07-10",
  "preview_urls": false,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "DEEPSEEK_BASE_URL": "https://api.deepseek.com",
    "DEEPSEEK_MODEL": "deepseek-v4-flash",
    "DAILY_AI_UNIT_LIMIT": "120"
  },
  "d1_databases": [
    {
      "binding": "USAGE_DB",
      "database_name": "roco-shortdrama-usage",
      "database_id": "dc4a522f-7c60-476c-aca5-b1ba01eebd3c",
      "migrations_dir": "migrations"
    }
  ]
}
