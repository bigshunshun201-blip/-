{
  "name": "rock-kingdom-shortdrama-studio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node scripts/build-public.mjs",
    "test": "node --test",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "start": "node server.js",
    "deploy:cloudflare": "npm run build && npx.cmd wrangler deploy",
    "dev:cloudflare": "npm run build && npx.cmd wrangler dev"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "jsonrepair": "^3.13.1",
    "lucide": "^1.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
